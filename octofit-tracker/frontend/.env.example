VITE_CODESPACE_NAME=
# Define VITE_CODESPACE_NAME in your environment (for example create a file named
# `.env.local` in this folder). When set, the frontend will target the Codespaces
# preview URL: https://${import.meta.env.VITE_CODESPACE_NAME}-8000.app.github.dev
# Example .env.local content:
# VITE_CODESPACE_NAME=my-codespace-name
# Note: after changing env files restart the Vite dev server.
